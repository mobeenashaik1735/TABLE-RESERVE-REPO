# Database Connection (Optional, falls back to in-memory SQLite out-of-the-box in AI Studio)
DATABASE_URL=

# JWT Authentication Secret (Optional, has a secure built-in fallback)
JWT_SECRET=

# Email SMTP Notification Credentials (Optional, console fallback in development)
EMAIL_USER=
EMAIL_PASS=

# Twilio SMS Notification Credentials (Optional, console fallback in development)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Stripe Payment Key (Optional, console fallback in development)
STRIPE_SECRET_KEY=

# Port configuration
PORT=
